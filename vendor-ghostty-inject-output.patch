+    /// Inject output data into the surface's terminal as if it came
+    /// from the PTY. This is used for tmux control mode integration
+    /// where output is received over a control connection and needs
+    /// to be fed into the terminal emulator.
+    export fn ghostty_surface_inject_output(
+        surface: *Surface,
+        ptr: [*]const u8,
+        len: usize,
+    ) void {
+        const termio = @import("../termio.zig");
+        const core = &surface.core_surface;
+        const msg = termio.Message.injectReq(
+            core.alloc,
+            ptr[0..len],
+        ) catch return;
+        core.io.queueMessage(msg, .unlocked);
+    }
